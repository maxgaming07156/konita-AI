// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Required Models ─────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())

  accounts     Account[]
  sessions     Session[]
  translations TranslationRecord[]
  favorites    FavoriteWord[]
  preferences  UserPreference?
  stats        Stats?
  activity     Activity[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Data Models ──────────────────────────────────────────────────────────

model TranslationRecord {
  id             String   @id @default(cuid())
  userId         String
  sourceText     String
  translatedText String
  sourceLang     String
  targetLang     String
  timestamp      BigInt
  tutorData      Json?    // Stores the TutorBreakdown object

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, timestamp(sort: Desc)])
}

model FavoriteWord {
  id          String   @id @default(cuid())
  userId      String
  word        String
  translation String
  sourceLang  String
  targetLang  String
  meaning     String?
  timestamp   BigInt
  srsBox      Int      @default(0)
  srsDueAt    BigInt?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word, targetLang])
}

model UserPreference {
  id                String @id @default(cuid())
  userId            String @unique
  defaultSourceLang String @default("auto")
  defaultTargetLang String @default("es")
  autoSpeak         Boolean @default(false)
  voiceRate         Float   @default(1.0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Stats {
  id                        String @id @default(cuid())
  userId                    String @unique
  totalTranslations         Int    @default(0)
  totalConversationMessages Int    @default(0)
  languagesPracticed        String[] // Array of language codes
  longestStreak             Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id     String @id @default(cuid())
  userId String
  date   String // "YYYY-MM-DD" format

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}
